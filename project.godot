; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[  ]
_global_script_class_icons={

}

[application]

config/name="Wandering Civilization"
config/icon="res://icon.png"

[autoload]

Global="*res://Assets/Scripts/Global.gd"

[display]

window/size/width=1920
window/size/height=1080
window/stretch/mode="2d"
window/stretch/aspect="keep"

[layer_names]

2d_physics/layer_1="combination"
2d_physics/layer_2="player_combination"
2d_physics/layer_3="enemy_combination"
2d_physics/layer_4="projectile"
2d_physics/layer_5="player_projectile"
2d_physics/layer_6="enemy_projectile"

[physics]

2d/default_gravity=0
2d/default_gravity_vector=Vector2( 0, 0 )

[rendering]

environment/default_environment="res://default_env.tres"
